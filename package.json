{
  "name": "hermes-forge",
  "version": "0.1.1",
  "description": "Local-first, community-hackable desktop forge for Hermes Agent.",
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/Mahiruxia/hermes-forge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mahiruxia/hermes-forge.git"
  },
  "bugs": {
    "url": "https://github.com/Mahiruxia/hermes-forge/issues"
  },
  "main": "dist/main/main/index.js",
  "private": false,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "npm run build && electron .",
    "build": "npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.main.json",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "test": "vitest run",
    "package:win": "npm run build && electron-builder --win nsis portable",
    "package:mac": "npm run build && electron-builder --mac dmg zip",
    "package:portable": "npm run build && electron-builder --win portable"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "jsdom": "^26.1.0",
    "lucide-react": "^1.8.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "dev.hermesforge.desktop",
    "productName": "Hermes Forge",
    "publish": [
      {
        "provider": "github",
        "owner": "Mahiruxia",
        "repo": "hermes-forge"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/sql.js/**/*",
      "node_modules/zod/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "resources/hermes-windows-mcp-server.py",
        "to": "hermes-windows-mcp-server.py"
      },
      {
        "from": "resources/hermes-headless-runner.py",
        "to": "hermes-headless-runner.py"
      }
    ],
    "win": {
      "icon": "assets/icons/hermes-workbench.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "assets/icons/hermes-workbench.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
