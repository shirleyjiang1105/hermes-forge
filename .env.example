# Hermes runtime
HERMES_HOME=
HERMES_AGENT_HOME=

# Optional OpenAI-compatible local model endpoint
OPENAI_BASE_URL=http://127.0.0.1:8081/v1
OPENAI_MODEL=
OPENAI_API_KEY=

# Optional OpenRouter provider
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Optional Anthropic provider
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_API_KEY=

# Windows bridge values are normally generated at runtime.
HERMES_WINDOWS_BRIDGE_URL=
HERMES_WINDOWS_BRIDGE_TOKEN=
